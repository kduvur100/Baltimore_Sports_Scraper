# ─────────────────────────────────────────────
# Baltimore Sports Hub — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# --- Backend ---
PORT=8080

# PostgreSQL (Supabase connection string also works here)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/baltimore_sports?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# CORS — set to your frontend URL in production
FRONTEND_URL=http://localhost:5173

# --- Reddit API (optional — uncomment scraper in manager.go when ready) ---
# Create app at: https://www.reddit.com/prefs/apps (choose "script")
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=BaltimoreSportsBot/1.0 by u/yourusername

# --- Bluesky AT Protocol (optional) ---
# Create app password at: https://bsky.app → Settings → App Passwords
# BLUESKY_IDENTIFIER=yourhandle.bsky.social
# BLUESKY_APP_PASSWORD=

# --- YouTube Data API v3 (optional) ---
# Enable at: https://console.cloud.google.com → APIs & Services
# YOUTUBE_API_KEY=

# --- Frontend ---
# Leave empty to use Vite's local proxy (dev). Set in Vercel env vars for production.
VITE_API_URL=
API_URL=http://localhost:8080
